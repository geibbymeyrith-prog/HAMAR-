rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - role: string (required, 'user'|'admin')
    //   - subscriptionStatus: string (required, 'free'|'monthly'|'yearly')
    //   - subscriptionEndDate: timestamp (optional)
    //   - whatsappConsultationsUsed: number (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: calculations
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required)
    //   - type: string (required, 'weton'|'jodoh'|'hariBaik')
    //   - inputData: map (required)
    //   - resultData: map (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: posts
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - content: string (required)
    //   - excerpt: string (optional)
    //   - authorId: string (required)
    //   - featuredImage: string (optional)
    //   - isPremium: bool (required)
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         (request.auth.token.email == "geibbymeyrith@gmail.com" && request.auth.token.email_verified == true));
    }

    function isSubscriber() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.subscriptionStatus in ['monthly', 'yearly'];
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUser(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() < 100 &&
             data.role in ['user', 'admin'] &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             (!('fullName' in data) || (data.fullName is string && data.fullName.size() < 100)) &&
             (!('whatsapp' in data) || (data.whatsapp is string && data.whatsapp.size() < 30)) &&
             (!('birthDate' in data) || data.birthDate is map) &&
             (!('generateCount' in data) || data.generateCount is number) &&
             (!('temporaryUnlock' in data) || data.temporaryUnlock is bool) &&
             (!('premiumExpiredAt' in data) || data.premiumExpiredAt is timestamp) &&
             (!('subscriptionStatus' in data) || data.subscriptionStatus is string);
    }

    function isValidHistory(data) {
      return data.userId == request.auth.uid &&
             data.type in ['weton', 'jodoh', 'hariBaik'] &&
             data.label is string &&
             data.details is map &&
             data.createdAt is timestamp;
    }

    function isValidArticle(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.author is string && data.author.size() < 100 &&
             data.content is string && data.content.size() <= 1000 &&
             data.visibility in ['public', 'member'] &&
             data.status in ['draft', 'published'];
    }

    function isValidPayment(data) {
      return data.userId == request.auth.uid &&
             data.name is string && data.name.size() < 100 &&
             data.email is string && data.email.size() < 100 &&
             data.whatsapp is string && data.whatsapp.size() < 30 &&
             data.package in ['11000', '111000', '1111000'] &&
             data.uniqueAmount is number &&
             data.status == 'pending' &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == 'user' || (request.resource.data.role == 'admin' && request.auth.token.email == "geibbymeyrith@gmail.com"));
      allow update: if isAdmin() || (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role);
    }

    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidPayment(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }

    match /history/{historyId} {
      allow list, get: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidHistory(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /articles/{articleId} {
      allow read: if (resource.data.status == 'published' && (resource.data.visibility == 'public' || (resource.data.visibility == 'member' && isAuthenticated()))) || isAdmin();
      allow write: if isAdmin() && isValidArticle(request.resource.data);
    }
  }
}
