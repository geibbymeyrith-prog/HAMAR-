rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - role: string (required, 'user'|'admin')
    //   - subscriptionStatus: string (required, 'free'|'monthly'|'yearly')
    //   - subscriptionEndDate: timestamp (optional)
    //   - whatsappConsultationsUsed: number (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: calculations
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required)
    //   - type: string (required, 'weton'|'jodoh'|'hariBaik')
    //   - inputData: map (required)
    //   - resultData: map (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: posts
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - content: string (required)
    //   - excerpt: string (optional)
    //   - authorId: string (required)
    //   - featuredImage: string (optional)
    //   - isPremium: bool (required)
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         (request.auth.token.email == "geibbymeyrith@gmail.com" && request.auth.token.email_verified == true));
    }

    function isSubscriber() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.subscriptionStatus in ['monthly', 'yearly'];
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUser(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() < 100 &&
             data.role in ['user', 'admin'] &&
             data.subscriptionStatus in ['free', 'monthly', 'yearly'] &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             (!('whatsappConsultationsUsed' in data) || data.whatsappConsultationsUsed is number) &&
             (!('subscriptionEndDate' in data) || data.subscriptionEndDate is timestamp);
    }

    function isValidCalculation(data) {
      return data.userId == request.auth.uid &&
             data.type in ['weton', 'jodoh', 'hariBaik'] &&
             data.inputData is map && data.resultData is map &&
             data.inputData.keys().size() < 20 && data.resultData.keys().size() < 50;
    }

    function isValidPost(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 50000 &&
             data.isPremium is bool &&
             (!('excerpt' in data) || (data.excerpt is string && data.excerpt.size() < 500));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == 'user' || (request.resource.data.role == 'admin' && request.auth.token.email == "geibbymeyrith@gmail.com"));
      allow update: if isAdmin() || (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role);
    }

    match /test/connection {
      allow read: if true;
    }

    match /calculations/{calcId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidCalculation(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /posts/{postId} {
      allow read: if true;
      allow write: if isAdmin() && isValidPost(request.resource.data);
    }
  }
}
