{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and subscription status",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "whatsapp": { "type": "string" },
        "fullName": { "type": "string" },
        "birthDate": { "type": "object" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "subscriptionStatus": { "type": "string", "enum": ["free", "monthly", "yearly"] },
        "premiumExpiredAt": { "type": "string", "format": "date-time" },
        "generateCount": { "type": "number" },
        "temporaryUnlock": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Manual payment record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "whatsapp": { "type": "string" },
        "package": { "type": "string" },
        "uniqueAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "email", "whatsapp", "package", "uniqueAmount", "status", "createdAt"]
    },
    "History": {
      "title": "History",
      "description": "Saved calculation results for a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["weton", "jodoh", "hariBaik"] },
        "label": { "type": "string" },
        "details": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "label", "details", "createdAt"]
    },
    "Article": {
      "title": "Article",
      "description": "Blog article content",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "author": { "type": "string" },
        "content": { "type": "string" },
        "contentHtml": { "type": "string" },
        "visibility": { "type": "string", "enum": ["public", "member"] },
        "status": { "type": "string", "enum": ["draft", "published"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "author", "content", "visibility", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/history/{historyId}": {
      "schema": "History",
      "description": "Calculation history"
    },
    "/articles/{articleId}": {
      "schema": "Article",
      "description": "Blog articles"
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Payment records"
    }
  }
}
