{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and subscription status",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "subscriptionStatus": { "type": "string", "enum": ["free", "monthly", "yearly"] },
        "subscriptionEndDate": { "type": "string", "format": "date-time" },
        "premiumExpiredAt": { "type": "string", "format": "date-time" },
        "generateCount": { "type": "number" },
        "temporaryUnlock": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "subscriptionStatus"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Manual payment record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "whatsapp": { "type": "string" },
        "package": { "type": "string" },
        "uniqueAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "email", "whatsapp", "package", "uniqueAmount", "status", "createdAt"]
    },
    "Calculation": {
      "title": "Calculation",
      "description": "Saved calculation history for a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["weton", "jodoh", "hariBaik"] },
        "inputData": { "type": "object" },
        "resultData": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "inputData", "resultData", "createdAt"]
    },
    "BlogPost": {
      "title": "BlogPost",
      "description": "Blog article content",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "excerpt": { "type": "string" },
        "authorId": { "type": "string" },
        "featuredImage": { "type": "string" },
        "isPremium": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "authorId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/calculations/{calcId}": {
      "schema": "Calculation",
      "description": "Calculation history"
    },
    "/posts/{postId}": {
      "schema": "BlogPost",
      "description": "Blog posts"
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Payment records for manual verification"
    }
  }
}
